{
	"name": "save-as-root",
	"displayName": "Save as Root in Remote - SSH",
	"description": "Edit configuration files with root privileges while using the Remote - SSH extension",
	"version": "1.10.0",
	"publisher": "yy0931",
	"engines": {
		"vscode": "^1.57.0"
	},
	"repository": {
		"url": "https://github.com/yy0931/save-as-root",
		"type": "git"
	},
	"bugs": {
		"url": "https://github.com/yy0931/save-as-root/issues"
	},
	"icon": "icon.png",
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onCommand:save-as-root.saveFile",
		"onCommand:save-as-root.saveFileAsSpecifiedUser",
		"onCommand:save-as-root.newFile"
	],
	"keywords": [
		"remote",
		"ssh",
		"root",
		"sudo"
	],
	"main": "./extension.js",
	"contributes": {
		"commands": [
			{
				"command": "save-as-root.saveFile",
				"title": "Save as Root"
			},
			{
				"command": "save-as-root.saveFileAsSpecifiedUser",
				"title": "Save as Specified User…"
			},
			{
				"command": "save-as-root.newFile",
				"title": "New File as Root..."
			}
		],
		"configuration": {
			"properties": {
				"save-as-root.command": {
					"type": "string",
					"default": "sudo"
				},
				"save-as-root.files.encoding": {
					"type": "string",
					"default": "utf8",
					"enum": ["utf8", "utf8bom", "utf16le", "utf16be", "windows1252", "iso88591", "iso88593", "iso885915", "macroman", "cp437", "windows1256", "iso88596", "windows1257", "iso88594", "iso885914", "windows1250", "iso88592", "cp852", "windows1251", "cp866", "iso88595", "koi8r", "koi8u", "iso885913", "windows1253", "iso88597", "windows1255", "iso88598", "iso885910", "iso885916", "windows1254", "iso88599", "windows1258", "gbk", "gb18030", "cp950", "big5hkscs", "shiftjis", "eucjp", "euckr", "windows874", "iso885911", "koi8ru", "koi8t", "gb2312", "cp865", "cp850"],
					"markdownDescription": "The encoding used to write the file content. This is a temporary solution for saving with non-UTF-8 encodings until https://github.com/microsoft/vscode/pull/177434 is merged."
				}
			}
		},
		"menus": {
			"explorer/context": [
				{
					"command": "save-as-root.newFile",
					"group": "navigation@9",
					"when": "resourceScheme == file && explorerResourceIsFolder && remoteName != ''"
				}
			]
		}
	},
	"capabilities": {
		"virtualWorkspaces": false,
		"untrustedWorkspaces": {
			"supported": "limited",
			"restrictedConfigurations": [
				"save-as-root.command"
			]
		}
	},
	"dependencies": {
		"iconv-lite": "^0.6.3"
	}
}
